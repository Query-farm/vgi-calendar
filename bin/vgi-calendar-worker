#!/usr/bin/env bash
# Launch wrapper so DuckDB's vgi extension can spawn this Python worker via a plain
# filesystem LOCATION:
#   ATTACH 'cal' (TYPE vgi, LOCATION '/path/to/vgi-calendar/bin/vgi-calendar-worker');
#
# The worker speaks Arrow IPC over stdin/stdout (Worker.run()). `uv run` resolves the
# project's environment (vgi-python + holidays + python-dateutil) and execs the console
# script; uv's own diagnostics go to stderr, so stdout stays a clean Arrow IPC stream.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec uv run --project "$REPO_ROOT" --quiet vgi-calendar-worker "$@"
